
<% layout("/layouts/boilerplate") %>

<script>
    let mapToken = "<%=process.env.MAP_TOKEN%>";
    let listing = <%-JSON.stringify(listings)%> ;

</script>

<body> 


    <div class="row mt-3">

        <div class="col-8 offset-3">
            <h3><%=listings.title %></h3>
        </div>


        <div class="card col-6 offset-3 listing-card">
            <img src="<%= listings.image.url %>" class="card-img-top show-img mb-1" alt="listing_image">
            <div class="card-body">

                 <p class="card-text">Owned by <%= listings.owner.username %></p>
                 <p class="card-text">  <%=listings.description %></p>
                
                     
                 <p class="card-text">    &#8377;  <%=listings.price.toLocaleString("en-IN") %> </p>
                 <p class="card-text">   <%=listings.location %></p>
                 <p class="card-text">   <%=listings.country %> </p>

               
            </div>
        </div>
    

        <% if(currUser && currUser._id.equals(listings.owner._id)){ %>
            <div class="btns ">
                <a href="/listings/<%=listings._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>
    
                <form method="post" action="/listings/<%=listings._id %>?_method=DELETE">
                <button class="btn  btn-dark offset-4">Delete</button>
                </form>
            </div>
        <% }  %>

        <% if(currUser){ %>
        <div class="col-8 offset-3 mb-3 ">
            <hr>
            <h4>Leave a review</h4>
            <form action="/listings/<%= listings._id %>/reviews" method="POST" novalidate class="needs-validation">

               
                              
                    
                 <div class="mt-3">
                    <label for="rating" class="form-label">Rating</label>
                <fieldset class="starability-slot">
                     
                        
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
               </div>




                <div class=" mb-3">
                    <label for="comment" class="form-label">comment</label>
                    <textarea name="review[comment]" id="comment" rows="5" cols="8" class="form-control" required></textarea>
                    <div class="invalid-feedback">please enter a comment</div>
                </div>

                <button class="btn btn-outline-primary">Submit</button>
            </form>

        </div>
        <% }  %>
       

        <div class="col-8 offset-3">
             <hr>
            <% if(listings.reviews.length > 0)  { %>
             <p><b>All reviews</b></p>  


               <div class="row">
           
                    <% for(review of listings.reviews) { %>
                    <div class="card col-5 mb-3 ms-3">
                        <div class="card-body"></div>
                        <h5 class="card-title">@<%=review.author.username %></h5>
                         <p class="starability-result card-text" data-rating="<%= review.rating%>"> </p> 
                        <p class="card-text"><%= review.comment%></p>
                        
                       
                          

                        <form method="POST" action="/listings/<%=listings._id %>/reviews/<%=review._id %>?_method=DELETE" >
                            <button class="btn btn-sm btn-outline-danger mb-3 ">Delete</button>
                        </form>

                    </div>

                    <% }%>
                </div>
                <hr> 
                <% }%>
        
        </div>
       
        <div class="col-8 offset-3 mb-3"> 
            
            <h3>Where you'll be</h3>
            <div id="map"></div>

        </div>

    </div>     
   
    <script src="/js/map.js"></script>
 
    
</body>
